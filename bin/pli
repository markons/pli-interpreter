#!/bin/sh
# PL/I interpreter launcher (Unix): bin/pli program.pli
# Works from any directory; the pli package lives one level up from
# this script.
DIR="$(cd "$(dirname "$0")/.." && pwd)"
PY="$(command -v python3 || command -v python)"
PYTHONPATH="$DIR${PYTHONPATH:+:$PYTHONPATH}" exec "$PY" -m pli "$@"
